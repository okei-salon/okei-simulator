{
  "name": "oukei-hub",
  "private": true,
  "scripts": {
    "dev": "firebase emulators:start --only hosting --project oukei-hub",
    "start": "npm run dev",
    "serve": "npm run dev",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "hosting:cleanup": "node scripts/hosting-cleanup.cjs",
    "hosting:cleanup:dry-run": "node scripts/hosting-cleanup.cjs --dry-run",
    "deploy:hosting:safe": "npm run hosting:cleanup && npm run deploy:hosting",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "validate:hub": "python3 tools/hub_validate_unified.py merge-output/OUKEI_HUB_KAI2_UNIFIED_v2_20260711.hub",
    "fetch:orca-firestore": "python3 scripts/fetch-orca-from-firestore.py",
    "embed:orca-hub": "python3 tools/hub_embed_orca_org.py",
    "verify:hub-restore": "node scripts/verify-restore-hub.mjs",
    "verify:eni-optin": "node scripts/verify-eni-optin.mjs",
    "verify:eni-performance": "node scripts/verify-eni-performance-input.mjs",
    "verify:hub-sync": "node scripts/verify-hub-sync-merge.mjs",
    "verify:orca-account-delete": "node scripts/verify-orca-account-full-delete.mjs",
    "verify:local-dev-mode": "node scripts/verify-local-dev-mode.mjs",
    "verify:org-visibility": "node scripts/verify-org-chart-visibility.mjs",
    "verify:org-localhost": "node scripts/verify-org-chart-localhost.mjs"
  },
  "devDependencies": {
    "firebase-tools": "^13.29.1"
  }
}
